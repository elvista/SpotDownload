# =============================================================================
# CrateDigger — single repo-root .env for FastAPI (:8000) + Vite (:5173).
# Register Spotify redirect URIs in the Developer Dashboard (must match .env exactly):
#   - http://127.0.0.1:8000/api/auth/spotify/callback   (Spotify ID — note 127.0.0.1, NOT 127.0.01)
#   - http://127.0.0.1:8000/api/mixtape/spotify/callback (optional Mixtape-only OAuth)
# =============================================================================

# --- Spotify (shared app credentials) ---
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Must use 127.0.0.1 (Spotify rejects http://localhost for redirect URIs). Match exactly in the Dashboard.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/auth/spotify/callback
# Where to send the browser after Spotify login (optional; Spotify does not validate this)
# FRONTEND_ORIGIN=http://localhost:5173
DOWNLOAD_PATH=~/Music/CrateDigger
MONITOR_INTERVAL_MINUTES=30
# Parallel yt-dlp downloads (1–8; default 3). Higher values can help on fast disks but may increase throttling.
# DOWNLOAD_CONCURRENCY=3
# Optional: encrypt stored Spotify tokens at rest
# ENCRYPTION_KEY=

# --- Genre ID (genre classification) ---
LASTFM_API_KEY=your_lastfm_api_key_here
# Claude API is used as fallback when Last.fm can't identify a track
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Mixtape ID (fingerprinting — required for analysis) ---
ACRCLOUD_ACCESS_KEY=your_acrcloud_access_key
ACRCLOUD_ACCESS_SECRET=your_acrcloud_access_secret
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
AUDD_API_TOKEN=your_audd_api_token

# --- Mixtape: Spotify playlist export (optional) ---
# Default: connect Spotify once in the app under Spotify ID → Settings (same token creates Mixtape playlists).
# Optional: SPOTIFY_REFRESH_TOKEN=... or Mixtape-only OAuth (/api/mixtape/spotify/login) if you skip Settings.
# SPOTIFY_REFRESH_TOKEN=

# Override default Mixtape-only OAuth callback (only if you use /api/mixtape/spotify/login)
# SPOTIFY_REDIRECT_URI_MIXID=http://127.0.0.1:8000/api/mixtape/spotify/callback
