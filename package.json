{
  "name": "spotdownload-workspace",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd backend && ./venv/bin/uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
